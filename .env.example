# Copy this file to .env and fill in your values.

# PostgreSQL connection string.
# Format: postgres://USERNAME:PASSWORD@HOST:PORT/DATABASE
# Replace YOUR_PASSWORD with the password you set during PostgreSQL installation.
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@127.0.0.1:5432/appdb

# Secret used to sign session cookies. Change this to any long random string.
SESSION_SECRET=replace-this-with-any-long-random-string-at-least-32-chars

# Optional: comma-separated frontend origins allowed to call the API with cookies (required in production).
# Example: https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGIN=

# Set to true when deployed behind Render/Vercel/nginx so secure cookies work correctly.
TRUST_PROXY=true

# Frontend (Vercel): optional override for API URL. Defaults to Render URL in production builds.
# VITE_API_BASE=https://alshamail.onrender.com/api
